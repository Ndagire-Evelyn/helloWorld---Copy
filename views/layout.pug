doctype html
head
  meta(charset='UTF-8')
  meta(name='viewport' content='width=device-width, initial-scale=1.0')
  title Log In
  link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css' rel='stylesheet')
  link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css' rel='stylesheet')
  link(rel='stylesheet' href='public/css/styles.css')
nav.navbar
  .navbar-container
    div
      a.navbar-logo(href='/auth/login') P
      h5#h5 ParkEase
    button.navbar-toggle
      span.bar
      span.bar
      span.bar
    ul.navbar-menu
      li
        a.active(href='/') Home
        if user 
          if user.role === "Admin"
            li
                a(href='/admin') Dashboard
            li
                a(href="/usersList") Manage Users
          if user.role === "Manager"
            li
                a(href='/manager') Dashboard
            li
                a(href="/registerBattery") Battery Services
            li
                a(href="/tyreServices") Tyre Clinic
          if user.role === "Attendant"
            li
                a(href='/attendant') Dashboard
            li
                a(href="/registerVehicle") Check in
            li
                a(href="/signout") Vehicle Signout
    div.d-flex.ms-lg-3.align-items-center
        if user 
          span.text-light.me-3.small 
            i.fa-solid.fa-user-circle.me-1 
            | Hi, #{user.firstName}
            span.badge.bg-secondary.ms-1 #{user.role}
          a.btn.btn-outline-danger.btn-sm.fw-bold(href="/auth/logout") Log Out
        else 
          a.btn.btn-outline.light.me-2(href="/auth/login") Log in
block content
footer.site-footer
  .footer-content
    p
      | &copy; 2026 ParkEase. All services served.
      br
      |  Smart Parking
