extends layout
block content 
    .bg-white.p-3.shadow-sm.d-flex.justify-content-between
    div
        button.btn.btn-primary.btn-sm(onclick='downloadPDF()')
        | Download PDF
        button.btn.btn-outline-secondary.btn-sm(onclick='exportCSV()')
        | Export CSV
    .container.mt-4
    h4 DAILY REPORTS
    // DATE
    .d-flex.justify-content-between.mb-3
        div
        button.btn.btn-light.btn-sm(onclick='changeDate(-1)')
            | &#x25C0;
        span#dateDisplay
        button.btn.btn-light.btn-sm(onclick='changeDate(1)')
            | &#x25B6;
        div
        input#searchInput.form-control.d-inline.w-auto(placeholder='Search plate or receipt')
        button.btn.btn-primary.btn-sm(onclick='loadData()')
            | Search
    // METRICS
    .row.mb-4
        .col-md-4
        .metric
            | Parking Revenue
            br
            strong#parking UGX 0
        .col-md-4
        .metric
            | Tyre Clinic
            br
            strong UGX 0
        .col-md-4
        .metric
            | Battery Hire
            br
            strong UGX 0
    // TABLE
    .card.p-3
        table.table
        thead
            tr
            th Receipt
            th Plate
            th In-Time
            th Out-Time
            th Duration
            th Fee
        tbody#table
        strong
        | Total: UGX 
        span#total 0
    // footer
    footer.site-footer
    .footer-content
        p
        | &copy; 2026 ParkEase. All services served.
        br
        |           Smart Parking
