extends layout 
block content      
    table
            thead
            tr
                th Battery image
                th batteryType
                th batterySize
            tbody
                if batteries.length 
                    each battery in batteries 
                        tr
                            td 
                                img(src = "/" + battery.batteryImage alt = "Battery image" width = "150px" height = "170px")
                            td #{battery.batteryType}
                            td #{battery.batterySize}